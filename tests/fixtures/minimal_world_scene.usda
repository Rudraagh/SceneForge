#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "World"
{
    def Xform "blackboard_1"
    {
        double3 xformOp:translate = (0, 0, -550)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "mars_2"
    {
        double3 xformOp:translate = (-200, 0, -20)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "pine_tree_3"
    {
        double3 xformOp:translate = (-550, 0, -400)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
